# === Required ===
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_CHAT_ID=987654321

# === CLI Backend ===
# Options: claude, gemini, codex, openrouter
CLI_BACKEND=claude

# Backend-specific (only the one you use):
# ANTHROPIC_API_KEY=sk-ant-...       # for claude
# GEMINI_API_KEY=AIza...             # for gemini (FREE: https://aistudio.google.com/apikey)
# OPENAI_API_KEY=sk-...              # for codex (or use: codex login --device-auth)
# OPENROUTER_API_KEY=sk-or-...       # for openrouter (FREE models: https://openrouter.ai)
# OPENROUTER_MODEL=meta-llama/llama-4-maverick:free

# === Optional ===
# Groq API key for voice messages (free: https://console.groq.com/keys)
GROQ_API_KEY=

# CLI timeout in seconds
# CLI_TIMEOUT=600

# Memory (auto-save session facts)
# MEMORY_ENABLED=true
# MEMORY_INJECT_LIMIT=5
